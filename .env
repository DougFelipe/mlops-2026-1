# Environment mode for the application (e.g., "dev" or "prod", if prod, requires access_token in the request header)
ENV="dev"

# Weights & Biases API Key (for model fetching)
# You can find this in your W&B settings: https://wandb.ai/settings
WANDB_API_KEY="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"

# Loading models from wandb (multiple models can be loaded if their urls are split by ',')
WANDB_MODELS="tomazfil-team/MLOPS-ATV3/confusion_intents-clf:v0,tomazfil-team/MLOPS-ATV3/clair_intents-clf:v0" 

## MongoDB local via Docker Compose (o container app acessa pelo nome do serviço 'mongo')
## Para restaurar o Atlas, substitua pela URI: mongodb+srv://douglas:MLOPS-ATV3@mlops-lab3.f8jvipd.mongodb.net/?appName=MLOPS-LAB3
MONGO_URI="mongodb://mongo:27017"
MONGO_DB="MLOPS-LAB3"